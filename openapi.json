{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Code Intelligence Platform API",
    "description": "Comprehensive automation platform connecting OpenAI and GitHub APIs with advanced storage, real-time processing, and extensive third-party integrations",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://your-space-name.hf.space",
      "description": "Production server on Hugging Face Spaces"
    }
  ],
  "paths": {
    "/api/user": {
      "get": {
        "summary": "Get current user information",
        "operationId": "getCurrentUser",
        "responses": {
          "200": {
            "description": "User information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/api/repositories": {
      "get": {
        "summary": "List all repositories",
        "operationId": "getRepositories",
        "responses": {
          "200": {
            "description": "List of repositories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Repository"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/repositories/sync": {
      "post": {
        "summary": "Sync repositories from GitHub",
        "operationId": "syncRepositories",
        "responses": {
          "200": {
            "description": "Sync completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "synced": {
                      "type": "number"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/repositories/{id}/analyze": {
      "post": {
        "summary": "Start AI analysis of a repository",
        "operationId": "analyzeRepository",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "analysisType": {
                    "type": "string",
                    "enum": ["quality", "security", "performance", "documentation"]
                  },
                  "filePath": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          }
        }
      }
    },
    "/api/insights": {
      "get": {
        "summary": "Get AI-generated insights",
        "operationId": "getInsights",
        "responses": {
          "200": {
            "description": "List of insights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Insight"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/workflows": {
      "get": {
        "summary": "Get automation workflows",
        "operationId": "getWorkflows",
        "responses": {
          "200": {
            "description": "List of workflows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workflow"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create new automation workflow",
        "operationId": "createWorkflow",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "trigger": {
                    "type": "string",
                    "enum": ["push", "pull_request", "schedule", "manual"]
                  },
                  "config": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workflow created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workflow"
                }
              }
            }
          }
        }
      }
    },
    "/api/stats": {
      "get": {
        "summary": "Get platform statistics",
        "operationId": "getStats",
        "responses": {
          "200": {
            "description": "Platform statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stats"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "githubId": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          }
        }
      },
      "Repository": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "stars": {
            "type": "integer"
          },
          "qualityScore": {
            "type": "number"
          },
          "lastAnalyzed": {
            "type": "string"
          }
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "repositoryId": {
            "type": "integer"
          },
          "filePath": {
            "type": "string"
          },
          "analysisType": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "qualityScore": {
            "type": "number"
          },
          "results": {
            "type": "object"
          }
        }
      },
      "Insight": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": ["optimization", "security", "documentation", "performance"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Workflow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "lastRun": {
            "type": "string"
          }
        }
      },
      "Stats": {
        "type": "object",
        "properties": {
          "repositories": {
            "type": "integer"
          },
          "analyses": {
            "type": "integer"
          },
          "workflows": {
            "type": "integer"
          },
          "qualityScore": {
            "type": "number"
          }
        }
      }
    }
  }
}