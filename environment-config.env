# AI Code Intelligence Platform Environment Configuration
# Copy these variables to your Hugging Face Space settings

# OpenAI Configuration (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (Required)
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# GitHub Integration (Required for repository features)
GITHUB_TOKEN=your_github_personal_access_token_here

# Optional GitHub OAuth (for advanced authentication)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=/auth/github/callback

# Application Configuration
NODE_ENV=production
PORT=7860